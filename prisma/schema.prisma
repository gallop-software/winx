generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BlogLike {
  post_id Int
  anon_id String

  @@id([post_id, anon_id])
  @@map("blog_likes")
}

model BlogPostSeed {
  post_id    Int      @id
  seed_count Int      @default(0)
  seeded_at  DateTime @default(now())

  @@map("blog_post_seeds")
}

model BlogShareIntent {
  post_id    Int
  target     String
  count      Int      @default(0)
  updated_at DateTime @default(now())

  @@id([post_id, target])
  @@map("blog_share_intents")
}
