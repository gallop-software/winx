generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BlogLike {
  post_id Int
  anon_id String

  @@id([post_id, anon_id])
  @@map("blog_likes")
}

model Subscriber {
  email      String   @id
  first_name String?
  last_name  String?
  subscribed Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("subscribers")
}

model BlogShareIntent {
  post_id    Int
  target     String
  count      Int      @default(0)
  updated_at DateTime @default(now())

  @@id([post_id, target])
  @@map("blog_share_intents")
}
