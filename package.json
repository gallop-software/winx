{
  "name": "winx",
  "version": "1.0.0",
  "private": true,
  "description": "Founder Notes — an independent publication for startup founders, with essays on product strategy, fundraising, hiring, and the day-to-day work of building an early-stage company.",
  "homepage": "https://winx.gallop.software",
  "author": {
    "name": "Gallop",
    "url": "https://gallop.software"
  },
  "contributors": [
    {
      "name": "Chris Baldelomar",
      "url": "https://github.com/webplantmedia"
    },
    {
      "name": "Niel Wostan",
      "url": "https://github.com/NielWostan"
    }
  ],
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "npm run blog && next build",
    "postinstall": "prisma generate",
    "db:generate": "npx prisma generate",
    "db:migrate": "prisma migrate dev",
    "start": "next start",
    "lint": "eslint src/",
    "lint:file": "eslint",
    "prettier": "prettier --write .",
    "ts": "tsc --noEmit",
    "lint:next": "eslint src/ --rule 'gallop/no-client-blocks: off' --rule 'gallop/no-container-in-section: off' --rule 'gallop/prefer-component-props: off'",
    "lint:gallop": "eslint 'src/app/**/_blocks/' --rule 'gallop/no-client-blocks: warn' --rule 'gallop/no-container-in-section: warn' --rule 'gallop/prefer-component-props: warn'",
    "audit": "gallop audit",
    "audit:strict": "gallop audit --strict",
    "audit:json": "gallop audit --json",
    "search": "./_scripts/generate-search.sh",
    "blog": "node _scripts/generate-blog-metadata.mjs",
    "blocks": "node _scripts/generate-blocks-catalog.mjs",
    "blocks:screenshots": "node _scripts/generate-blocks-catalog.mjs --screenshots",
    "blocks:sort": "node _scripts/generate-blocks-catalog.mjs --sort",
    "layouts": "node _scripts/generate-layouts-catalog.mjs",
    "layouts:screenshots": "node _scripts/generate-layouts-catalog.mjs --screenshots",
    "layouts:sort": "node _scripts/generate-layouts-catalog.mjs --sort",
    "bust:kv": "node _scripts/bust-kv-cache.mjs",
    "env": "./_scripts/push-env-to-vercel.sh",
    "env:prod": "./_scripts/push-env-to-vercel.sh production",
    "env:prev": "./_scripts/push-env-to-vercel.sh preview",
    "refresh": "rm -rf node_modules .next && npm install",
    "clean": "rm -rf node_modules .next package-lock.json && npm install",
    "update:check": "npx npm-check-updates",
    "update:patch": "npx npm-check-updates -u --target patch && npm run clean",
    "update:minor": "npx npm-check-updates -u --target minor && npm run clean",
    "update:major": "npx npm-check-updates -u --target latest && npm run clean",
    "update:interactive": "npx npm-check-updates -i",
    "update:doctor": "npx npm-check-updates --doctor -u",
    "unused": "knip",
    "check": "npm run lint && npm run ts"
  },
  "dependencies": {
    "@algolia/autocomplete-core": "^1.19.8",
    "@headlessui/react": "^2.2.10",
    "@iconify/icons-heroicons": "^1.2.9",
    "@iconify/icons-lucide": "^1.2.135",
    "@iconify/icons-mdi": "^1.2.48",
    "@iconify/icons-simple-icons": "^1.2.74",
    "@iconify/types": "^2.0.0",
    "@next/third-parties": "^16.2.4",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/kv": "^3.0.0",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.38.0",
    "html-react-parser": "^6.0.1",
    "jsdom": "^27.4.0",
    "luxon": "^3.7.2",
    "next": "^16.2.4",
    "react": "^19",
    "react-dom": "^19.2.5",
    "react-highlight-words": "^0.21.0",
    "react-intersection-observer": "^10.0.3",
    "server-only": "^0.0.1",
    "swiper": "^12.1.4",
    "valtio": "^2.3.1",
    "yet-another-react-lightbox": "^3.31.0"
  },
  "devDependencies": {
    "@gallop.software/canon": "^2.34.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-highlight-words": "^0.20.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "knip": "^5.88.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.2.0",
    "puppeteer": "^24.42.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
