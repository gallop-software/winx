# ===========================================
# Production Environment
# ===========================================
# Rename this file to .env.production
# Or set these values in Vercel:
# vercel.com/[your-project]/settings/environment-variables
# ===========================================

NEXT_PUBLIC_PRODUCTION_URL=https://yourdomain.com
NEXT_PUBLIC_WORDPRESS_URL=https://your-wordpress-instance.com

# Mailgun (contact form / submit-form API)
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN_NAME=mg.yourdomain.com
MAILGUN_FROM_NAME="Your Business"
MAILGUN_SMTP_MAIL=contact@yourdomain.com
MAILGUN_DEV_NAME="Your Name"
MAILGUN_DEV_MAIL=you@example.com

# Cloudflare R2 CDN (for Studio image sync)
CLOUDFLARE_R2_ACCOUNT_ID=your-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_R2_PUBLIC_URL=https://your-cdn-domain.com

# Recommended for most uses
DATABASE_URL=postgresql://user:password@host/dbname?channel_binding=require&sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# Parameters for constructing your own connection string
PGHOST=your-pooled-host
PGHOST_UNPOOLED=your-unpooled-host
PGUSER=your-db-user
PGDATABASE=your-db-name
PGPASSWORD=your-db-password

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://user:password@host/dbname?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?channel_binding=require&sslmode=require
POSTGRES_USER=your-db-user
POSTGRES_HOST=your-pooled-host
POSTGRES_PASSWORD=your-db-password
POSTGRES_DATABASE=your-db-name
POSTGRES_URL_NO_SSL=postgresql://user:password@host/dbname
POSTGRES_PRISMA_URL=postgresql://user:password@host/dbname?channel_binding=require&connect_timeout=15&sslmode=require

# Vercel KV / Upstash Redis
KV_REST_API_READ_ONLY_TOKEN="your-kv-read-only-token"
KV_REST_API_TOKEN="your-kv-token"
KV_REST_API_URL="https://your-instance.upstash.io"
KV_URL="rediss://default:your-token@your-instance.upstash.io:6379"
REDIS_URL="rediss://default:your-token@your-instance.upstash.io:6379"
